[Unit]
Description=PC Status Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=comp5
WorkingDirectory=/home/comp5/pc-status-dashboard
Environment=PATH=/home/comp5/pc-status-dashboard/.venv/bin
ExecStart=/home/comp5/pc-status-dashboard/.venv/bin/python /home/comp5/pc-status-dashboard/status_dashboard.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
