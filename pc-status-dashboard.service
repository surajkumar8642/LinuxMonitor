[Unit]
Description=PC Status Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=comp5
WorkingDirectory=/home/comp5/work/git/LinixMoniter
Environment=PATH=/home/comp5/work/git/LinixMoniter/.venv/bin
ExecStart=/home/comp5/work/git/LinixMoniter/.venv/bin/python /home/comp5/work/git/LinixMoniter/status_dashboard.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
